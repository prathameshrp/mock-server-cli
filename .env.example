# Copy this file to `.env` and edit the values you want to change.
# docker-compose.prod.yml reads from `.env` automatically.
#
# ─────────────────────────────────────────────────────────────────────
# IMPORTANT — defaults are HTTP-only on purpose.
#
# If you set DOMAIN to a real hostname you don't own, or one whose DNS
# isn't pointing at this VM yet, Caddy will hammer Let's Encrypt and
# get you rate-limited for ~1 week (5 failed validations per hostname
# per hour). So the default below is `:80` — plain HTTP on the VM's
# public IP, no TLS attempt. Flip to a real hostname only once DNS is
# correct (verify with `dig +short mocks.yourdomain.com`).
# ─────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────
# Domain & TLS
# ────────────────────────────────────────────────────────────────────

# `:80`                    plain HTTP on the VM's public IP, no TLS.
#                          Safe default; lets you smoke-test first.
# `mocks.yourdomain.com`   Caddy auto-issues a Let's Encrypt cert.
#                          DNS A record MUST already point at this VM
#                          (check with `dig +short mocks.yourdomain.com`).
DOMAIN=:80

# (Cert-expiry notices via email are off by default. If you want them,
# add `email you@yourdomain.com` inside the global block of
# docker/Caddyfile.)

# ────────────────────────────────────────────────────────────────────
# Gateway
# ────────────────────────────────────────────────────────────────────

# The base URL the gateway uses when constructing cursor-pagination
# `next_page` links. Must match whatever external callers see.
#
# For HTTP-on-IP:  PUBLIC_BASE_URL=http://<vm-public-ip>
# For HTTPS:       PUBLIC_BASE_URL=https://mocks.yourdomain.com
#
# Leave blank to fall back to X-Forwarded-Host headers (works behind
# Caddy but less reliable through extra proxies).
PUBLIC_BASE_URL=
